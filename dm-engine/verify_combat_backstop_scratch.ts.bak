/* eslint-disable */
// Verificación manual (Jest roto en este sandbox) de los dos arreglos nuevos:
// 1) NoMutationYetError: un fallo de DeepSeek en la PRIMERA llamada del turno
//    (antes de cualquier tool) debe distinguirse de un fallo tras haber
//    llamado a alguna tool -- el primero es seguro reintentar, el segundo no.
// 2) combatWithoutToolsNudge: si la narrativa da por muerto a alguien pero no
//    se llamó a NINGUNA tool de combate real (start_combat/resolve_attack/
//    cast_spell), se fuerza una corrección -- reproduce el bug real donde
//    "Atacar"/"Lanza misil magico" resolvió un combate entero con 3 goblins
//    muertos sin tocar el sistema de combate en absoluto.
import { ChatClient, ChatCompletionResult, ChatMessage, ToolCaller, McpToolInfo, ToolDefinition } from './src/ports';
import { runDmTurn, NoMutationYetError } from './src/dm-turn';

class FakeChatClient implements ChatClient {
  private i = 0;
  public readonly receivedCalls: { messages: ChatMessage[]; tools: ToolDefinition[] }[] = [];
  constructor(private readonly responses: ChatCompletionResult[]) {}
  async createCompletion(params: { messages: ChatMessage[]; tools: ToolDefinition[] }): Promise<ChatCompletionResult> {
    this.receivedCalls.push(params);
    const response = this.responses[this.i];
    this.i = Math.min(this.i + 1, this.responses.length - 1);
    return response;
  }
}

class ThrowingChatClient implements ChatClient {
  private i = 0;
  constructor(private readonly steps: (ChatCompletionResult | Error)[]) {}
  async createCompletion(): Promise<ChatCompletionResult> {
    const step = this.steps[Math.min(this.i, this.steps.length - 1)];
    this.i += 1;
    if (step instanceof Error) throw step;
    return step;
  }
}

class FakeToolCaller implements ToolCaller {
  public readonly calls: { name: string; args: Record<string, unknown> }[] = [];
  constructor(
    private readonly tools: McpToolInfo[] = [],
    private readonly results: Record<string, unknown> = {},
  ) {}
  async listTools(): Promise<McpToolInfo[]> { return this.tools; }
  async callTool(name: string, args: Record<string, unknown>): Promise<unknown> {
    this.calls.push({ name, args });
    return this.results[name] ?? {};
  }
}

async function main() {
  // 1) Fallo en la PRIMERA llamada -> NoMutationYetError, cero tools llamadas.
  {
    const chatClient = new ThrowingChatClient([new Error('DeepSeek: 429 rate limited')]);
    const toolCaller = new FakeToolCaller();
    try {
      await runDmTurn(chatClient, toolCaller, [{ role: 'user', content: 'Atacar' }], 'g1');
      throw new Error('FALLO 1: debería haber lanzado');
    } catch (err) {
      if (!(err instanceof NoMutationYetError)) throw new Error(`FALLO 1: no fue NoMutationYetError: ${err}`);
      if (toolCaller.calls.length !== 0) throw new Error('FALLO 1: no debería haber llamado a ninguna tool');
    }
    console.log('OK 1/4: fallo en la primera llamada -> NoMutationYetError (seguro reintentar).');
  }

  // 2) Fallo DESPUÉS de haber llamado a una tool -> error normal, NO NoMutationYetError.
  {
    const chatClient = new ThrowingChatClient([
      {
        message: {
          role: 'assistant', content: null,
          tool_calls: [{ id: 'c1', type: 'function', function: { name: 'roll_dice', arguments: '{"notation":"1d20"}' } }],
        },
      },
      new Error('DeepSeek: 500 fallo transitorio'),
    ]);
    const toolCaller = new FakeToolCaller([], { roll_dice: { result: 14 } });
    try {
      await runDmTurn(chatClient, toolCaller, [{ role: 'user', content: 'Tiro para percibir' }], 'g1');
      throw new Error('FALLO 2: debería haber lanzado');
    } catch (err) {
      if (err instanceof NoMutationYetError) throw new Error('FALLO 2: NO debería ser NoMutationYetError (ya se llamó a roll_dice)');
      if (!(err instanceof Error) || !err.message.includes('500 fallo transitorio')) throw new Error(`FALLO 2: mensaje inesperado: ${err}`);
    }
    console.log('OK 2/4: fallo tras haber llamado a una tool -> error normal (NO reintentable a ciegas).');
  }

  // 3) Combate resuelto por texto libre SIN ninguna tool -> se corrige.
  {
    const chatClient = new FakeChatClient([
      { message: { role: 'assistant', content: 'Lanzas un misil mágico. El goblin cae muerto al instante.' } },
      { message: { role: 'assistant', content: '¡Tira los dados! (corregido)' } },
    ]);
    const toolCaller = new FakeToolCaller();
    const result = await runDmTurn(chatClient, toolCaller, [{ role: 'user', content: 'Lanzo misil magico' }], 'g1');
    if (result.narrative !== '¡Tira los dados! (corregido)') throw new Error(`FALLO 3: narrativa inesperada: ${result.narrative}`);
    if (chatClient.receivedCalls.length !== 2) throw new Error(`FALLO 3: se esperaban 2 llamadas, hubo ${chatClient.receivedCalls.length}`);
    const correctionMsgs = chatClient.receivedCalls[1].messages;
    const lastMsg = correctionMsgs[correctionMsgs.length - 1];
    if (!/start_combat|resolve_attack|cast_spell/.test(lastMsg.content ?? '')) {
      throw new Error(`FALLO 3: el aviso correctivo no menciona las tools reales: ${lastMsg.content}`);
    }
    console.log('OK 3/4: "misil mágico mata a un goblin" sin NINGUNA tool -> corregido (bug real reproducido y arreglado).');
  }

  // 4) Si SÍ se llamó a start_combat (y se colocó a su enemigo, para no disparar
  // el aviso PREEXISTENTE de "faltan enemigos por colocar"), no se corrige por
  // el chequeo NUEVO aunque la narrativa mencione una muerte.
  {
    const chatClient = new FakeChatClient([
      {
        message: {
          role: 'assistant', content: null,
          tool_calls: [
            { id: 'c1', type: 'function', function: { name: 'start_combat', arguments: '{"gameId":"g1","enemyIds":["enemy-1"]}' } },
            { id: 'c2', type: 'function', function: { name: 'place_participant', arguments: '{"gameId":"g1","participantId":"enc-1-a","row":0,"col":0}' } },
          ],
        },
      },
      { message: { role: 'assistant', content: 'El combate empieza. Un goblin cae muerto en la primera embestida.' } },
    ]);
    const toolCaller = new FakeToolCaller([], {
      start_combat: { enemies: [{ instanceId: 'enc-1-a' }] },
      place_participant: { placed: true },
    });
    const result = await runDmTurn(chatClient, toolCaller, [{ role: 'user', content: 'Ataco' }], 'g1');
    if (result.narrative !== 'El combate empieza. Un goblin cae muerto en la primera embestida.') {
      throw new Error(`FALLO 4: se corrigió sin necesidad: ${result.narrative}`);
    }
    if (chatClient.receivedCalls.length !== 2) throw new Error(`FALLO 4: hubo una corrección de más (${chatClient.receivedCalls.length} llamadas)`);
    console.log('OK 4/4: start_combat SÍ llamado -> ninguna corrección de más, pese a mencionar una muerte.');
  }

  console.log('\n✅ TODO OK: NoMutationYetError + combatWithoutToolsNudge verificados.');
}

main().catch((err) => {
  console.error('❌ ERROR:', err);
  process.exit(1);
});
