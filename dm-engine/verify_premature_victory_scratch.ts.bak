/* eslint-disable */
// Verificación manual (Jest roto en este sandbox) del chequeo anti-victoria-
// prematura en dm-turn.ts, reproduciendo el bug real reportado: un Brown Bear
// con 34 HP recibe 9 de daño acumulado (25 HP reales) y el DM narra su muerte
// + otorga XP como si el combate hubiera terminado.
import { ChatClient, ChatCompletionResult, ChatMessage, ToolCaller, McpToolInfo, ToolDefinition } from './src/ports';
import { runDmTurn } from './src/dm-turn';

class FakeChatClient implements ChatClient {
  private i = 0;
  public readonly receivedCalls: { messages: ChatMessage[]; tools: ToolDefinition[] }[] = [];
  constructor(private readonly responses: ChatCompletionResult[]) {}
  async createCompletion(params: { messages: ChatMessage[]; tools: ToolDefinition[] }): Promise<ChatCompletionResult> {
    this.receivedCalls.push(params);
    const response = this.responses[this.i];
    this.i = Math.min(this.i + 1, this.responses.length - 1);
    return response;
  }
}

class FakeToolCaller implements ToolCaller {
  public readonly calls: { name: string; args: Record<string, unknown> }[] = [];
  constructor(
    private readonly tools: McpToolInfo[] = [],
    private readonly results: Record<string, unknown> = {},
  ) {}
  async listTools(): Promise<McpToolInfo[]> { return this.tools; }
  async callTool(name: string, args: Record<string, unknown>): Promise<unknown> {
    this.calls.push({ name, args });
    return this.results[name] ?? {};
  }
}

async function main() {
  // 1) El bug real: ataca al oso, sigue vivo (25 HP), el DM declara victoria -> debe corregirse.
  {
    const chatClient = new FakeChatClient([
      {
        message: {
          role: 'assistant', content: null,
          tool_calls: [
            { id: 'c1', type: 'function', function: { name: 'resolve_attack', arguments: '{"gameId":"g1","targetId":"bear-1","attackerModifier":0,"targetArmorClass":11,"damageDice":"1d4","playerD20":11}' } },
            { id: 'c2', type: 'function', function: { name: 'grant_xp', arguments: '{"characterId":"char-1","amount":200}' } },
          ],
        },
      },
      { message: { role: 'assistant', content: 'Has vencido al oso. El cadáver yace a tus pies.' } },
      { message: { role: 'assistant', content: 'El oso sigue en pie, malherido, y ataca de nuevo.' } },
    ]);
    const toolCaller = new FakeToolCaller([], {
      resolve_attack: { hit: true, attackRoll: 11, damage: 4 },
      grant_xp: { levelUp: false },
      get_game_state: { activeEncounter: { enemies: [{ instanceId: 'bear-1', name: 'Brown Bear', currentHp: 25 }] } },
    });

    const result = await runDmTurn(chatClient, toolCaller, [], 'g1');
    if (result.narrative !== 'El oso sigue en pie, malherido, y ataca de nuevo.') {
      throw new Error(`FALLO 1: narrativa inesperada: ${result.narrative}`);
    }
    if (toolCaller.calls.map((c) => c.name).join(',') !== 'resolve_attack,grant_xp,get_game_state') {
      throw new Error(`FALLO 1: llamadas inesperadas: ${toolCaller.calls.map((c) => c.name).join(',')}`);
    }
    console.log('OK 1/4: victoria prematura contra Brown Bear (25 HP reales) detectada y corregida.');
  }

  // 2) Ataque que SÍ mata (HP real 0) -- no debe avisar victoria prematura. Se
  // incluyen advance_to_player_round Y end_combat en la misma respuesta para
  // aislar el chequeo bajo prueba de los otros dos avisos (no relacionados):
  // "ronda no reabierta" y el nuevo "combate no cerrado" (ver
  // verify_end_combat_nudge_scratch.ts para ese chequeo en detalle).
  {
    const chatClient = new FakeChatClient([
      {
        message: {
          role: 'assistant', content: null,
          tool_calls: [
            { id: 'c1', type: 'function', function: { name: 'resolve_attack', arguments: '{"gameId":"g1","targetId":"goblin-1","attackerModifier":2,"targetArmorClass":13,"damageDice":"1d6"}' } },
            { id: 'c2', type: 'function', function: { name: 'grant_xp', arguments: '{"characterId":"char-1","amount":50}' } },
            { id: 'c3', type: 'function', function: { name: 'advance_to_player_round', arguments: '{"gameId":"g1"}' } },
            { id: 'c4', type: 'function', function: { name: 'end_combat', arguments: '{"gameId":"g1"}' } },
          ],
        },
      },
      { message: { role: 'assistant', content: 'El goblin cae muerto. Has ganado 50 XP.' } },
    ]);
    const toolCaller = new FakeToolCaller([], {
      resolve_attack: { hit: true, damage: 7 },
      grant_xp: { levelUp: false },
      advance_to_player_round: { advanced: true },
      end_combat: { combatEnded: true },
      get_game_state: { activeEncounter: { enemies: [{ instanceId: 'goblin-1', name: 'Goblin', currentHp: 0 }] } },
    });

    const result = await runDmTurn(chatClient, toolCaller, [], 'g1');
    if (result.narrative !== 'El goblin cae muerto. Has ganado 50 XP.') throw new Error('FALLO 2: se corrigió sin necesidad');
    // 2 llamadas esperadas SIN corrección: una que devuelve los tool_calls (ya
    // viene dada) + una que devuelve la narrativa final tras procesarlos. Una
    // ronda de corrección real añadiría una 3ª llamada.
    if (chatClient.receivedCalls.length !== 2) throw new Error(`FALLO 2: hubo una ronda de corrección extra (${chatClient.receivedCalls.length} llamadas)`);
    console.log('OK 2/4: muerte real (HP 0) + end_combat ya llamado -> no dispara ningún aviso.');
  }

  // 3) Varios enemigos: uno muere (HP 0), otro sigue vivo pero NO fue atacado este turno -- no debe avisar.
  {
    const chatClient = new FakeChatClient([
      {
        message: {
          role: 'assistant', content: null,
          tool_calls: [
            { id: 'c1', type: 'function', function: { name: 'resolve_attack', arguments: '{"gameId":"g1","targetId":"goblin-1","attackerModifier":2,"targetArmorClass":13,"damageDice":"1d6"}' } },
            { id: 'c2', type: 'function', function: { name: 'grant_xp', arguments: '{"characterId":"char-1","amount":50}' } },
            { id: 'c3', type: 'function', function: { name: 'advance_to_player_round', arguments: '{"gameId":"g1"}' } },
          ],
        },
      },
      { message: { role: 'assistant', content: 'El goblin cae muerto, pero su compañero sigue en pie.' } },
    ]);
    const toolCaller = new FakeToolCaller([], {
      resolve_attack: { hit: true, damage: 7 },
      grant_xp: { levelUp: false },
      advance_to_player_round: { advanced: true },
      get_game_state: {
        activeEncounter: {
          enemies: [
            { instanceId: 'goblin-1', name: 'Goblin', currentHp: 0 },
            { instanceId: 'goblin-2', name: 'Goblin', currentHp: 7 },
          ],
        },
      },
    });

    const result = await runDmTurn(chatClient, toolCaller, [], 'g1');
    if (result.narrative !== 'El goblin cae muerto, pero su compañero sigue en pie.') {
      throw new Error('FALLO 3: falso positivo con un segundo enemigo vivo no atacado este turno');
    }
    if (chatClient.receivedCalls.length !== 2) throw new Error(`FALLO 3: hubo una ronda de corrección extra (${chatClient.receivedCalls.length} llamadas)`);
    console.log('OK 3/4: enemigo vivo no atacado este turno no genera falso positivo.');
  }

  // 4) grant_xp sin resolve_attack (ej. XP de misión) -- ni siquiera debe llamar a get_game_state.
  {
    const chatClient = new FakeChatClient([
      {
        message: {
          role: 'assistant', content: null,
          tool_calls: [{ id: 'c1', type: 'function', function: { name: 'grant_xp', arguments: '{"characterId":"char-1","amount":100}' } }],
        },
      },
      { message: { role: 'assistant', content: 'Habéis completado la misión. Ganáis 100 XP.' } },
    ]);
    const toolCaller = new FakeToolCaller([], { grant_xp: { levelUp: false } });

    const result = await runDmTurn(chatClient, toolCaller, [], 'g1');
    if (toolCaller.calls.map((c) => c.name).join(',') !== 'grant_xp') {
      throw new Error(`FALLO 4: llamó a algo más de lo esperado: ${toolCaller.calls.map((c) => c.name).join(',')}`);
    }
    console.log('OK 4/4: grant_xp sin resolve_attack no dispara ninguna comprobación extra.');
  }

  console.log('\n✅ TODO OK: chequeo de victoria prematura verificado.');
}

main().catch((err) => {
  console.error('❌ ERROR:', err);
  process.exit(1);
});
