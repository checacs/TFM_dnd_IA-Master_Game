import { ChatClient, ChatCompletionResult, ChatMessage, ToolCaller, McpToolInfo, ToolDefinition } from './src/ports';
import { runDmTurn } from './src/dm-turn';

class FakeChatClient implements ChatClient {
  private i = 0;
  public readonly receivedCalls: { messages: ChatMessage[]; tools: ToolDefinition[] }[] = [];
  constructor(private readonly responses: ChatCompletionResult[]) {}
  async createCompletion(params: { messages: ChatMessage[]; tools: ToolDefinition[] }): Promise<ChatCompletionResult> {
    this.receivedCalls.push(params);
    const response = this.responses[this.i];
    this.i = Math.min(this.i + 1, this.responses.length - 1);
    return response;
  }
}

class FakeToolCaller implements ToolCaller {
  public readonly calls: { name: string; args: Record<string, unknown> }[] = [];
  constructor(
    private readonly tools: McpToolInfo[] = [],
    private readonly results: Record<string, unknown> = {},
  ) {}
  async listTools(): Promise<McpToolInfo[]> { return this.tools; }
  async callTool(name: string, args: Record<string, unknown>): Promise<unknown> {
    this.calls.push({ name, args });
    return this.results[name] ?? {};
  }
}

async function main() {
  // Caso 1: EXACTAMENTE el bug real reportado -- el jugador escribe
  // "Muéstranos el mapa" y el DM responde afirmando que ya se está mostrando,
  // sin haber llamado a ninguna tool de mapa. Debe disparar el aviso, y en la
  // segunda vuelta el DM sí resuelve el mapa de verdad.
  const chat1 = new FakeChatClient([
    {
      message: {
        role: 'assistant',
        content: 'Veo que el mapa ya está mostrándose en el tablero. A vuestra derecha veis la puerta de Marta...',
      },
    },
    {
      message: {
        role: 'assistant',
        content: null,
        tool_calls: [{ id: 'c1', type: 'function' as const, function: { name: 'get_battle_maps', arguments: '{"tags":["molino"]}' } }],
      },
    },
    {
      message: {
        role: 'assistant',
        content: null,
        tool_calls: [{ id: 'c2', type: 'function' as const, function: { name: 'clear_battle_map', arguments: '{"gameId":"g1"}' } }],
      },
    },
    { message: { role: 'assistant', content: 'El tablero ahora refleja el interior del molino.' } },
  ]);
  const toolCaller1 = new FakeToolCaller([], { get_battle_maps: [], clear_battle_map: { cleared: true } });
  const history1: ChatMessage[] = [
    { role: 'assistant', content: 'Subís la escalera de caracol hasta un rellano con dos puertas.' },
    { role: 'user', content: 'Muéstranos el mapa' },
  ];
  const result1 = await runDmTurn(chat1, toolCaller1, history1, 'g1');
  console.log('CASO 1 (bug real) -> narrativa final:', result1.narrative);
  console.log('CASO 1 -> llamadas al modelo:', chat1.receivedCalls.length);
  const msgs1 = chat1.receivedCalls[1].messages;
  const correction1 = msgs1[msgs1.length - 1];
  console.log('CASO 1 -> aviso correctivo incluye "pedido explícitamente":', String(correction1.content).includes('pedido explícitamente'));
  if (chat1.receivedCalls.length < 2) throw new Error('FALLO CASO 1: no se disparó el aviso correctivo esperado');

  // Caso 2: control -- el jugador pide ver el mapa, pero el DM SÍ resuelve
  // el protocolo completo (describe_map -> set_battle_map -> place_participant)
  // en el mismo turno. No debe disparar NINGÚN aviso (ni el nuevo, ni el
  // preexistente de "mapa explorado pero no resuelto").
  const chat2 = new FakeChatClient([
    {
      message: {
        role: 'assistant', content: null,
        tool_calls: [{ id: 'c1', type: 'function' as const, function: { name: 'describe_map', arguments: '{"mapId":"casaEscondite1"}' } }],
      },
    },
    {
      message: {
        role: 'assistant', content: null,
        tool_calls: [{ id: 'c2', type: 'function' as const, function: { name: 'set_battle_map', arguments: '{"mapId":"casaEscondite1"}' } }],
      },
    },
    {
      message: {
        role: 'assistant', content: null,
        tool_calls: [{ id: 'c3', type: 'function' as const, function: { name: 'place_participant', arguments: '{"participantId":"san","zoneName":"Entrada"}' } }],
      },
    },
    { message: { role: 'assistant', content: 'Aquí tenéis el mapa del escondite.' } },
  ]);
  const toolCaller2 = new FakeToolCaller([], {
    describe_map: { mapId: 'casaEscondite1' },
    set_battle_map: { mapId: 'casaEscondite1' },
    place_participant: { placed: true },
  });
  // Historial de 3 mensajes (no 1 solo) para no disparar gameStartNudge por
  // accidente -- messages.length === 1 se interpreta ahora como el arranque
  // real de la partida (ver ese chequeo en dm-turn.ts).
  const history2: ChatMessage[] = [
    { role: 'user', content: 'La partida ha comenzado. Describe la escena inicial.' },
    { role: 'assistant', content: '¿Entráis en la taberna o os acercáis al tablón de anuncios?' },
    { role: 'user', content: 'Enseñanos el mapa por favor' },
  ];
  const result2 = await runDmTurn(chat2, toolCaller2, history2, 'g1');
  console.log('CASO 2 (control, mapa sí resuelto) -> llamadas al modelo:', chat2.receivedCalls.length);
  if (chat2.receivedCalls.length !== 4) throw new Error('FALLO CASO 2: se disparó un aviso donde no debía');

  // Caso 3: control -- el jugador NO pide el mapa (mensaje normal), no debe
  // disparar el nuevo aviso aunque el turno tampoco toque mapas. Historial de
  // 3 mensajes (no 1 solo) para no disparar gameStartNudge por accidente --
  // messages.length === 1 se interpreta ahora como el arranque real de la
  // partida (ver ese chequeo en dm-turn.ts).
  const chat3 = new FakeChatClient([{ message: { role: 'assistant', content: 'Marta os mira con desconfianza.' } }]);
  const toolCaller3 = new FakeToolCaller();
  const history3: ChatMessage[] = [
    { role: 'user', content: 'La partida ha comenzado. Describe la escena inicial.' },
    { role: 'assistant', content: '¿Entráis en la taberna o os acercáis al tablón de anuncios?' },
    { role: 'user', content: 'Le preguntamos por el colgante robado' },
  ];
  const result3 = await runDmTurn(chat3, toolCaller3, history3, 'g1');
  console.log('CASO 3 (control neutro) -> llamadas al modelo:', chat3.receivedCalls.length);
  if (chat3.receivedCalls.length !== 1) throw new Error('FALLO CASO 3: se disparó un aviso donde no debía');

  console.log('OK: el aviso de "jugador pide mapa explícitamente" se dispara solo cuando corresponde.');
}

main().catch((err) => { console.error(err); process.exit(1); });
