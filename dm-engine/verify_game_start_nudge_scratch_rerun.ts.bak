import { ChatClient, ChatCompletionResult, ChatMessage, ToolCaller, McpToolInfo, ToolDefinition } from './src/ports';
import { runDmTurn } from './src/dm-turn';

class FakeChatClient implements ChatClient {
  private i = 0;
  public readonly receivedCalls: { messages: ChatMessage[]; tools: ToolDefinition[] }[] = [];
  constructor(private readonly responses: ChatCompletionResult[]) {}
  async createCompletion(params: { messages: ChatMessage[]; tools: ToolDefinition[] }): Promise<ChatCompletionResult> {
    this.receivedCalls.push(params);
    const response = this.responses[this.i];
    this.i = Math.min(this.i + 1, this.responses.length - 1);
    return response;
  }
}

class FakeToolCaller implements ToolCaller {
  public readonly calls: { name: string; args: Record<string, unknown> }[] = [];
  constructor(
    private readonly tools: McpToolInfo[] = [],
    private readonly results: Record<string, unknown> = {},
  ) {}
  async listTools(): Promise<McpToolInfo[]> { return this.tools; }
  async callTool(name: string, args: Record<string, unknown>): Promise<unknown> {
    this.calls.push({ name, args });
    return this.results[name] ?? {};
  }
}

async function main() {
  // Caso 1: EXACTAMENTE el bug real reportado -- el turno 1 (el único
  // mensaje es el aviso sintético de arranque) responde en primera persona
  // y decide el destino por los jugadores, sin ofrecer elección. Debe
  // disparar el aviso, y en la segunda vuelta el DM corrige el arranque.
  const chat1 = new FakeChatClient([
    { message: { role: 'assistant', content: '¡Bien! Me acerco al tablón de anuncios. Vamos a ver que hay.' } },
    {
      message: {
        role: 'assistant',
        content:
          'El sol de media tarde cae sobre la plaza del pueblo. A un lado, la taberna bulle con risas; al ' +
          'otro, el tablón de anuncios del gremio de mercenarios cuelga lleno de contratos. ¿Entráis en la ' +
          'taberna o os acercáis al tablón de anuncios?',
      },
    },
  ]);
  const toolCaller1 = new FakeToolCaller();
  const history1: ChatMessage[] = [
    { role: 'user', content: 'La partida ha comenzado. Describe la escena inicial.' },
  ];
  const result1 = await runDmTurn(chat1, toolCaller1, history1, 'g1');
  console.log('CASO 1 (bug real) -> narrativa final:', result1.narrative);
  console.log('CASO 1 -> llamadas al modelo:', chat1.receivedCalls.length);
  const msgs1 = chat1.receivedCalls[1].messages;
  const correction1 = msgs1[msgs1.length - 1];
  console.log('CASO 1 -> aviso correctivo incluye "primerísimo turno":', String(correction1.content).includes('primerísimo turno'));
  if (chat1.receivedCalls.length !== 2) throw new Error('FALLO CASO 1: no se disparó el aviso correctivo esperado');
  if (!result1.narrative.includes('taberna') || !result1.narrative.includes('tablón')) {
    throw new Error('FALLO CASO 1: la narrativa final no ofrece ambos destinos');
  }

  // Caso 2: control -- turno 1 correcto desde el principio (narra en
  // segunda/tercera persona y ofrece ambos destinos). No debe disparar nada.
  const chat2 = new FakeChatClient([
    {
      message: {
        role: 'assistant',
        content:
          'Anochece sobre el pueblo de Piedra Hundida. El grupo se encuentra de pie en la plaza central. ' +
          '¿Entráis en la taberna o os acercáis al tablón de anuncios?',
      },
    },
  ]);
  const toolCaller2 = new FakeToolCaller();
  const history2: ChatMessage[] = [
    { role: 'user', content: 'La partida ha comenzado. Describe la escena inicial.' },
  ];
  const result2 = await runDmTurn(chat2, toolCaller2, history2, 'g1');
  console.log('CASO 2 (control, arranque correcto) -> llamadas al modelo:', chat2.receivedCalls.length);
  if (chat2.receivedCalls.length !== 1) throw new Error('FALLO CASO 2: se disparó un aviso donde no debía');

  // Caso 3: control -- NO es el turno 1 (ya hay historia previa), aunque el
  // texto mencione "me acerco" no debe disparar este chequeo concreto (el
  // check exige messageCount === 1).
  const chat3 = new FakeChatClient([
    { message: { role: 'assistant', content: 'Me acerco un poco más para mirar el pergamino con detalle.' } },
  ]);
  const toolCaller3 = new FakeToolCaller();
  const history3: ChatMessage[] = [
    { role: 'user', content: 'La partida ha comenzado. Describe la escena inicial.' },
    { role: 'assistant', content: '¿Entráis en la taberna o os acercáis al tablón de anuncios?' },
    // Sin mencionar "tablón"/"taberna" a propósito -- si no, esta narración
    // dispararía legítimamente el aviso de villageStartDestinationNudge (que
    // ahora también mira el último mensaje del jugador, no solo la
    // narración del DM), y este caso dejaría de ser un control neutro.
    { role: 'user', content: 'Miramos el pergamino de cerca' },
  ];
  const result3 = await runDmTurn(chat3, toolCaller3, history3, 'g1');
  console.log('CASO 3 (control, no es turno 1) -> llamadas al modelo:', chat3.receivedCalls.length);
  if (chat3.receivedCalls.length !== 1) throw new Error('FALLO CASO 3: se disparó el aviso de arranque fuera del turno 1');

  console.log('OK: el aviso de arranque de partida se dispara solo en el turno 1 y solo cuando corresponde.');
}

main().catch((err) => { console.error(err); process.exit(1); });
