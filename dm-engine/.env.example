DEEPSEEK_API_KEY=
# Verifica el id vigente en api-docs.deepseek.com (o la doc del proveedor que uses) antes de desplegar — cambia con frecuencia.
DEEPSEEK_MODEL=
# Opcional -- si no se define, usa https://api.deepseek.com. Cámbiala para usar
# cualquier otro proveedor compatible con la API de OpenAI (ej. Kimi K2/K3 de
# Moonshot: https://api.moonshot.ai/v1, con DEEPSEEK_MODEL=kimi-k3 y la key de
# platform.kimi.ai).
DEEPSEEK_BASE_URL=
# URL del servidor MCP de la API (docs/04-servidor-mcp.md).
MCP_SERVER_URL=http://localhost:3000/mcp
PORT=4000
