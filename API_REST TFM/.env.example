MONGODB_URI=
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Duración de la sesión: segundos (ej. 28800 = 8h) o notación "8h"/"7d". Si se omite, 7d.
JWT_EXPIRES_IN=28800
DM_ENGINE_URL=http://localhost:4000
# En Render, añade la URL de tu ui-web separada por comas:
# CORS_ORIGIN=

# TTS ("Escuchar al DM") -- Qwen3-TTS-Flash vía Alibaba Cloud Model Studio.
# Crea la API key en la consola de Model Studio, región Singapur:
# https://modelstudio.console.alibabacloud.com/?tab=dashboard#/api-key
# (ver README para el proceso completo de alta y recarga de saldo).
QWEN_TTS_API_KEY=
# Opcionales -- descomenta para cambiar los valores por defecto:
# QWEN_TTS_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
# QWEN_TTS_MODEL=qwen3-tts-flash
# QWEN_TTS_VOICE=Sonrisa
# QWEN_TTS_LANGUAGE=Spanish
